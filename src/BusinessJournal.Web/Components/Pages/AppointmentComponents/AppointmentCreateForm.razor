@using BusinessJournal.Web.Features.Appointments
@using BusinessJournal.Web.Features.Customers

@if (!string.IsNullOrWhiteSpace(FormError))
{
    <div class="alert alert-danger py-2 px-3 mb-3" role="alert">
        @FormError
    </div>
}

@if (!string.IsNullOrWhiteSpace(FormSuccess))
{
    <div class="alert alert-success py-2 px-3 mb-3" role="alert">
        @FormSuccess
    </div>
}

<EditForm Model="Model" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label fw-semibold">Customer</label>
        <select class="form-select"
                value="@GetSelectedCustomerValue()"
                @onchange="OnCustomerChanged">
            <option value="">-- select customer --</option>
            @foreach (var customer in Customers)
            {
                <option value="@customer.Id">@customer.FullName</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Title</label>
        <InputText class="form-control" @bind-Value="Model.Title" />
    </div>

    <div class="row g-3">
        <div class="col-12 col-md-6">
            <label class="form-label fw-semibold">Start</label>
            <input type="datetime-local"
                   class="form-control"
                   value="@Model.StartsAt"
                   @onchange="OnStartsAtChanged" />
        </div>

        <div class="col-12 col-md-6">
            <label class="form-label fw-semibold">End</label>
            <input type="datetime-local"
                   class="form-control"
                   value="@Model.EndsAt"
                   @onchange="OnEndsAtChanged" />
        </div>
    </div>

    <div class="mt-3 mb-4">
        <label class="form-label fw-semibold">Notes</label>
        <InputText class="form-control" @bind-Value="Model.Notes" />
    </div>

    <button class="btn btn-primary" type="submit" disabled="@IsSubmitting">
        @(IsSubmitting ? "Creating..." : "Create appointment")
    </button>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public CreateAppointmentInputModel Model { get; set; } = default!;

    [Parameter, EditorRequired]
    public IReadOnlyList<CustomerResponseModel> Customers { get; set; } = [];

    [Parameter]
    public Guid SelectedCustomerId { get; set; }

    [Parameter]
    public bool IsSubmitting { get; set; }

    [Parameter]
    public string? FormError { get; set; }

    [Parameter]
    public string? FormSuccess { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<ChangeEventArgs> OnCustomerChanged { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<ChangeEventArgs> OnStartsAtChanged { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<ChangeEventArgs> OnEndsAtChanged { get; set; }

    [Parameter, EditorRequired]
    public EventCallback OnSubmit { get; set; }

    private string GetSelectedCustomerValue()
    {
        return SelectedCustomerId == Guid.Empty
            ? string.Empty
            : SelectedCustomerId.ToString();
    }
}
