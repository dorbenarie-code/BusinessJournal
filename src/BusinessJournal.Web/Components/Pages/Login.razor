@page "/login"
@using BusinessJournal.Web.Features.Auth
@inject AuthApiClient AuthApiClient
@inject AuthSession AuthSession
@inject NavigationManager NavigationManager

<PageTitle>Login</PageTitle>

<div class="container-fluid py-4">
    <div class="mb-4">
        <h1 class="display-6 mb-2">Login</h1>
        <p class="text-muted mb-0">Sign in to access the BusinessJournal workspace.</p>
    </div>

    <div class="row g-4 align-items-start">
        <div class="col-12 col-xl-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="mb-4">
                        <h2 class="h4 mb-1">Account access</h2>
                        <p class="text-muted mb-0">
                            Use your credentials to manage customers and appointments.
                        </p>
                    </div>

                    @if (AuthSession.IsAuthenticated)
                    {
                        <div class="alert alert-success py-3 px-3 mb-4" role="alert">
                            <div class="fw-semibold mb-1">You are already signed in.</div>
                            <div class="mb-0">You can continue working in the system.</div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_successMessage))
                        {
                            <div class="alert alert-success py-2 px-3 mb-3" role="alert">
                                @_successMessage
                            </div>
                        }

                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-outline-secondary"
                                    type="button"
                                    @onclick="HandleSignOut">
                                Sign out
                            </button>

                            <button class="btn btn-primary"
                                    type="button"
                                    @onclick='() => NavigationManager.NavigateTo("/customers")'>
                                Go to customers
                            </button>

                            <button class="btn btn-outline-primary"
                                    type="button"
                                    @onclick='() => NavigationManager.NavigateTo("/appointments")'>
                                Go to appointments
                            </button>
                        </div>
                    }
                    else
                    {
                        @if (!string.IsNullOrWhiteSpace(_errorMessage))
                        {
                            <div class="alert alert-danger py-2 px-3 mb-3" role="alert">
                                @_errorMessage
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(_successMessage))
                        {
                            <div class="alert alert-success py-2 px-3 mb-3" role="alert">
                                @_successMessage
                            </div>
                        }

                        <EditForm Model="_model"
                                  OnValidSubmit="HandleValidSubmitAsync"
                                  OnInvalidSubmit="HandleInvalidSubmit">
                            <DataAnnotationsValidator />
                            <ValidationSummary />

                            <div class="mb-3">
                                <label class="form-label fw-semibold" for="email">Email</label>
                                <InputText id="email"
                                           class="form-control"
                                           placeholder="Enter your email"
                                           @bind-Value="_model.Email" />
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold" for="password">Password</label>
                                <InputText id="password"
                                           type="password"
                                           class="form-control"
                                           placeholder="Enter your password"
                                           @bind-Value="_model.Password" />
                            </div>

                            <div class="d-flex flex-wrap gap-2">
                                <button class="btn btn-primary px-4"
                                        type="submit"
                                        disabled="@_isSubmitting">
                                    @(_isSubmitting ? "Signing in..." : "Sign in")
                                </button>

                                <button class="btn btn-outline-secondary"
                                        type="button"
                                        @onclick="ClearForm"
                                        disabled="@_isSubmitting">
                                    Clear
                                </button>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="mb-4">
                        <h2 class="h4 mb-1">What you can do here</h2>
                        <p class="text-muted mb-0">
                            After signing in, the main system pages become available for daily work.
                        </p>
                    </div>

                    <div class="border rounded-3 p-3 mb-3 bg-light">
                        <div class="fw-semibold mb-1">Customers</div>
                        <div class="text-muted">
                            Create customers, browse the list, and search by name, phone number, or email.
                        </div>
                    </div>

                    <div class="border rounded-3 p-3 mb-3 bg-light">
                        <div class="fw-semibold mb-1">Appointments</div>
                        <div class="text-muted">
                            Create appointments, review records, and handle cancel or reschedule actions.
                        </div>
                    </div>

                    <div class="border rounded-3 p-3 bg-light">
                        <div class="fw-semibold mb-1">Simple and secure flow</div>
                        <div class="text-muted">
                            The system keeps the sign-in flow lightweight and uses your session automatically for protected API requests.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private readonly LoginInputModel _model = new();

    private bool _isSubmitting;
    private string? _errorMessage;
    private string? _successMessage;

    private void HandleInvalidSubmit()
    {
        _successMessage = null;
        _errorMessage = null;
    }

    private async Task HandleValidSubmitAsync()
    {
        _isSubmitting = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            var result = await AuthApiClient.LoginAsync(_model);

            if (!result.IsSuccess || result.Response is null)
            {
                _errorMessage = result.ErrorMessage ?? "Login failed.";
                return;
            }

            AuthSession.SetSession(
                result.Response.AccessToken,
                result.Response.ExpiresAtUtc);

            _successMessage = "Signed in successfully.";
            _model.Password = string.Empty;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void HandleSignOut()
    {
        AuthSession.Clear();
        _errorMessage = null;
        _successMessage = "You have been signed out.";
        ClearForm();
    }

    private void ClearForm()
    {
        _model.Email = string.Empty;
        _model.Password = string.Empty;
        _errorMessage = null;
    }
}